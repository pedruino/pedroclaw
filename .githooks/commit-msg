#!/usr/bin/env bash
#
# Validates commit messages against Conventional Commits v1.0.0
# https://www.conventionalcommits.org/en/v1.0.0/

commit_msg_file="$1"
commit_msg=$(head -1 "$commit_msg_file")

# Conventional commit pattern:
#   type(optional-scope)optional-!: description
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .{1,72}$'

if [[ ! "$commit_msg" =~ $pattern ]]; then
  echo ""
  echo "ERROR: Commit message does not follow Conventional Commits."
  echo ""
  echo "  Expected: <type>[optional scope]: <description>"
  echo "  Got:      $commit_msg"
  echo ""
  echo "  Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo "  Max subject length: 72 characters"
  echo ""
  echo "  Examples:"
  echo "    feat(webhook): add gitlab merge request handler"
  echo "    fix: correct token refresh logic"
  echo "    chore(deps): bump fastapi to 0.115"
  echo ""
  echo "  See: https://www.conventionalcommits.org/en/v1.0.0/"
  echo ""
  exit 1
fi
