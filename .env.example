# ============================================
# 3wclaw — Configuração
# Copie para .env e preencha seus valores
# ============================================

# --- GitLab ---
# URL da sua instância GitLab
GITLAB_URL=https://gitlab.com
# Token de acesso: GitLab > Preferences > Access Tokens (scope: api)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# Segredo do webhook: você inventa, depois usa o mesmo no GitLab > Settings > Webhooks
GITLAB_WEBHOOK_SECRET=invente-um-segredo-aqui

# --- IA pra Review de Código e Triage de Issues ---
# Modelo: claude-sonnet-4-6 | gpt-4o | deepseek/deepseek-chat
LLM_REVIEW_MODEL=claude-sonnet-4-6
# Chave da API: pega em https://console.anthropic.com > API Keys > Create Key
LLM_REVIEW_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Opcional: URL customizada pra modelos self-hosted (ex: Ollama)
# LLM_REVIEW_API_BASE=http://localhost:11434

# --- Motor de Review ---
# builtin = usa a IA diretamente | coderabbit = delega pro CodeRabbit | pr_agent = usa PR-Agent
REVIEW_ENGINE=builtin

# --- CodeRabbit (só se REVIEW_ENGINE=coderabbit) ---
# CODERABBIT_API_KEY=

# --- IA pra Base de Conhecimento (desabilitada por padrão) ---
# Modelo de embedding pra busca por similaridade entre issues
# LLM_KB_MODEL=text-embedding-3-small
# Chave da API pra embeddings (pode ser a mesma da review acima se for OpenAI)
# LLM_KB_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# --- Langfuse (Observabilidade) ---
# Habilita o rastreamento de LLM calls, traces e spans
LANGFUSE_ENABLED=true
# Pegar em: Langfuse UI > Settings > API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
# URL do Langfuse self-hosted (ou https://cloud.langfuse.com)
LANGFUSE_HOST=http://langfuse-web:3000
# Host OTEL pro callback do LiteLLM (mesma URL do Langfuse, dentro do Docker)
LANGFUSE_OTEL_HOST=http://langfuse-web:3000
# Segredos do Langfuse self-hosted (você inventa)
LANGFUSE_NEXTAUTH_SECRET=invente-um-segredo-aqui
LANGFUSE_SALT=invente-um-salt-aqui

# --- Banco de Dados (não precisa mudar se usar docker compose) ---
DATABASE_URL=postgresql+asyncpg://pedroclaw:pedroclaw@localhost:5432/pedroclaw

# --- Redis (não precisa mudar se usar docker compose) ---
REDIS_URL=redis://localhost:6379/0
